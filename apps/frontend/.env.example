# ─── Frontend Environment Variables ───────────────────────────────────────────

# Backend API URL (public, used by the browser for client-side API calls)
PUBLIC_API_URL=http://localhost:8080

# Backend URL (private, used by the server for SSR API calls)
# In Docker, this is the internal service name (e.g., http://backend:8080)
BACKEND_URL=http://localhost:8080

# SvelteKit adapter-node body size limit (default is 512KB)
# Set to 10MB to match the backend limit
BODY_SIZE_LIMIT=10485760
